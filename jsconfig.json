{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ESNext",
        "jsx": "react-jsx",
        "baseUrl": "./",
        "ignoreDeprecations": "6.0",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "src/**/*.jsx",
        "src/**/*.js"
    ]
}